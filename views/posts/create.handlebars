<div class="card">
  <h2 class="page-title">✏️ Create New Post</h2>
  <form action="/posts" method="POST">
    <label>Title</label>
    <input type="text" name="title" placeholder="Enter an interesting title..." required>
    
    <label>Author</label>
    <input type="text" name="author" placeholder="Your name" value="Sourav Jha">
    
    <label>Content</label>
    <textarea name="body" placeholder="Write something amazing..." required></textarea>
    
    <div class="actions">
      <button type="submit" class="btn btn-success">🚀 Publish Post</button>
      <a href="/posts" class="btn">❌ Cancel</a>
    </div>
  </form>
</div>