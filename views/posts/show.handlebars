<div class="card">
  <h2>{{post.title}}</h2>
  <div class="meta">
    <span>👤 {{post.author}}</span>
    <span>📅 {{post.date}}</span>
  </div>
  <p style="line-height:1.8; font-size:16px;">{{post.body}}</p>
  <br>
  <div class="actions">
    <a href="/posts" class="btn">⬅️ Back</a>
    <a href="/posts/{{post._id}}/edit" class="btn">✏️ Edit</a>
    <form action="/posts/{{post._id}}?_method=DELETE" method="POST" style="display:inline">
      <button type="submit" class="btn btn-danger">🗑 Delete</button>
    </form>
  </div>
</div>