{{#if posts.length}}
  {{#each posts}}
    <div class="card">
      <h2>{{this.title}}</h2>
      <div class="meta">
        <span>👤 {{this.author}}</span>
        <span>📅 {{this.date}}</span>
      </div>
      <p>{{this.body}}</p>
      <div class="actions">
        <a href="/posts/{{this._id}}" class="btn">👁 Read More</a>
        <a href="/posts/{{this._id}}/edit" class="btn">✏️ Edit</a>
        <form action="/posts/{{this._id}}?_method=DELETE" method="POST" style="display:inline">
          <button type="submit" class="btn btn-danger">🗑 Delete</button>
        </form>
      </div>
    </div>
  {{/each}}
{{else}}
  <div class="card empty-state">
    <h2>No posts yet!</h2>
    <p>Start sharing your thoughts with the world.</p>
    <a href="/posts/create" class="btn btn-success">✏️ Create First Post</a>
  </div>
{{/if}}